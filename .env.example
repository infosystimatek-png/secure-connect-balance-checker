# ---- Network selection ----
# mainnet | shasta
NETWORK=shasta

# ---- Nodes (set these for your infra/provider) ----
# Shasta public examples (replace for production)
FULL_NODE=https://api.shasta.trongrid.io
SOLIDITY_NODE=https://api.shasta.trongrid.io
EVENT_SERVER=https://api.shasta.trongrid.io

# Mainnet public examples (replace for production)
# FULL_NODE=https://api.trongrid.io
# SOLIDITY_NODE=https://api.trongrid.io
# EVENT_SERVER=https://api.trongrid.io

# ---- Treasury ----
TREASURY_ADDRESS=TXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Backend delegated signer key ----
# WARNING: store securely in production (HSM/KMS)
BACKEND_PRIVATE_KEY=YOUR_BACKEND_PRIVATE_KEY

# ---- Token contracts ----
# USDT on mainnet and Shasta differ. Fill the right one for your selected NETWORK.
USDT_CONTRACT_MAINNET=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
USDT_CONTRACT_SHASTA=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs

# ---- Permission name used in AccountPermissionUpdate ----
ACTIVE_PERMISSION_NAME=GAME_BACKEND

# ---- Operations bitmask for the delegated Active permission ----
# Example value widely referenced as "all operations except AccountPermissionUpdateContract":
# 7fff1fc0037e0000000000000000000000000000000000000000000000000000
ACTIVE_PERMISSION_OPERATIONS=7fff1fc0037e0000000000000000000000000000000000000000000000000000

# ---- Server ----
PORT=8787

# ---- WalletConnect (required for frontend TRON connect) ----
# Get a project ID at https://cloud.walletconnect.com
WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID_HERE
